# A2A Fincrime Detection Framework — Environment Variables
# Copy this file to .env and fill in your keys

# Dune Analytics API key (required for transaction data queries)
# Get yours at: https://dune.com/settings/api
DUNE_API_KEY=your_dune_api_key_here

# Base chain RPC URL (optional, for direct RPC fallback)
# Free options: https://chainlist.org/chain/8453
BASE_RPC_URL=https://mainnet.base.org

# Ethereum RPC URL (optional, for ERC-8004 on Ethereum mainnet)
ETH_RPC_URL=https://eth.llamarpc.com

# The Graph API key (optional, for higher rate limits on subgraph queries)
# Get yours at: https://thegraph.com/studio/apikeys/
GRAPH_API_KEY=
